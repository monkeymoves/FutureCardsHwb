---
interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <span class="logo-diamond"></span>
      <span class="logo-text">FUTURES</span>
    </a>
    <nav class="nav">
      <a href="/" class:list={['nav-link', { active: currentPage === 'home' }]}>Home</a>
      <a href="/game" class:list={['nav-link', { active: currentPage === 'play' || currentPage === 'lobby' }]}>Play</a>
      <a href="/about" class:list={['nav-link', { active: currentPage === 'about' }]}>Rules</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: rgba(250, 250, 248, 0.9);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-md) 0;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--color-text);
  }

  .logo:hover { text-decoration: none; }

  .logo-diamond {
    width: 18px;
    height: 18px;
    background: var(--color-blue);
    transform: rotate(45deg);
    border-radius: 3px;
  }

  .logo-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.05rem;
    letter-spacing: 0.14em;
  }

  .nav {
    display: flex;
    gap: var(--space-xs);
  }

  .nav-link {
    color: var(--color-text-secondary);
    font-weight: 500;
    font-size: 0.9rem;
    padding: 6px 14px;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-surface-raised);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--color-blue);
    background: var(--color-blue-light);
  }
</style>
