---
import GameLayout from '../layouts/GameLayout.astro';
---

<GameLayout title="Game">
  <div id="game-container">

    <!-- Phase announcement overlay — populated and shown by JS on every phase transition -->
    <div id="phase-announcement" class="phase-announcement" hidden></div>

    <header id="game-topbar">
      <div class="topbar-left">
        <a href="/" class="topbar-logo">
          <span class="logo-diamond"></span>
          <span>FUTURES</span>
        </a>
        <div class="topbar-divider" aria-hidden="true"></div>
        <button id="room-code-button" class="room-code" type="button">Room</button>
      </div>

      <div class="topbar-center" aria-label="Game phases">
        <div class="phase-pip active"></div>
        <div class="phase-pip"></div>
        <div class="phase-pip"></div>
        <div class="phase-pip"></div>
        <div class="phase-pip"></div>
        <span id="phase-label" class="phase-label">Setup: Define your starting situation and end goal</span>
      </div>

      <div class="topbar-right">
        <!-- Participants: synced rail with online dots and host badge.
             Real joiners arrive via the join-by-link flow (lobby → /framing → /game),
             so there's no manual "Add player" affordance here. -->
        <div id="participant-rail" class="participant-rail" aria-label="Session participants"></div>
        <div class="topbar-divider" aria-hidden="true"></div>
        <button id="tidy-board-btn" class="topbar-btn" type="button" title="Snap all cards back into the standard timeline layout">↕ Tidy</button>
        <button id="connect-mode-btn" class="topbar-btn connect-btn" type="button" title="Click two cards to draw a connection between them">⤴ Link</button>
        <div class="topbar-divider" aria-hidden="true"></div>
        <button id="prev-phase-btn" class="topbar-btn" type="button" style="display: none;">← Back</button>
        <button id="next-phase-btn" class="topbar-btn primary" type="button">Next: Planning →</button>
      </div>
    </header>

    <!-- Framing context strip — populated by JS from gameState.framing.
         Click to expand the full breakdown. Hidden until framing is completed. -->
    <details id="framing-strip" class="framing-strip" hidden>
      <summary class="framing-strip-summary">
        <span class="framing-strip-label">Framing</span>
        <span id="framing-strip-question" class="framing-strip-question"></span>
      </summary>
      <div class="framing-strip-body">
        <div class="framing-strip-row"><strong>Goal:</strong> <span id="framing-strip-goal"></span></div>
        <div class="framing-strip-row" id="framing-strip-track-row"><strong>Track:</strong> <span id="framing-strip-track"></span></div>
        <div class="framing-strip-actions">
          <button id="framing-edit-btn" type="button" class="framing-strip-edit-btn">✎ Edit framing</button>
        </div>
      </div>
    </details>

    <main id="board-viewport" aria-label="Game board">
      <div id="board-surface"></div>

      <div id="board-empty-prompt" class="board-empty-prompt">
        <h3>Build the future on the table</h3>
        <p>Place cards from the tray, click any card to edit it, and drag only when you want to reposition the board.</p>
      </div>

      <div id="zoom-controls" aria-label="Zoom controls">
        <button id="zoom-in" class="zoom-btn" type="button" aria-label="Zoom in">+</button>
        <div id="zoom-level" class="zoom-level">70%</div>
        <button id="zoom-out" class="zoom-btn" type="button" aria-label="Zoom out">−</button>
        <button id="zoom-reset" class="zoom-btn" type="button" aria-label="Reset view">⟳</button>
      </div>
    </main>

    <aside id="card-panel">
      <button id="panel-toggle" class="panel-toggle" type="button" aria-label="Toggle card panel">▶</button>

      <div class="panel-header">
        <div class="panel-kicker" id="panel-phase-status">Current Move</div>
        <div class="panel-title" id="panel-title">Card Tray</div>
        <p class="panel-copy" id="panel-copy">Click a card to place it, or drag it onto the table.</p>

        <!-- Facilitation prompt — collapsible so it doesn't crowd the card tray -->
        <details id="panel-faci-prompt" class="panel-faci-prompt" hidden>
          <summary class="panel-faci-label">Ask the group</summary>
          <div class="panel-faci-text" id="panel-faci-text"></div>
        </details>

        <div class="panel-mode-tabs" role="tablist" aria-label="Panel modes">
          <button class="panel-mode-tab active" type="button" data-panel-mode="cards">Cards</button>
          <button class="panel-mode-tab" type="button" data-panel-mode="story">Notebook</button>
        </div>

        <div id="panel-tabs" class="panel-tabs" role="tablist" aria-label="Card types">
          <button class="panel-tab" type="button" data-type="action" title="Action — build or adapt the path">
            <span class="panel-tab-title">Action</span>
            <span class="panel-tab-copy">Build or adapt the path</span>
          </button>
          <button class="panel-tab" type="button" data-type="curveball" title="Curveball — pressure the pathway">
            <span class="panel-tab-title">Curveball</span>
            <span class="panel-tab-copy">Pressure the pathway</span>
          </button>
          <button class="panel-tab" type="button" data-type="ripple" title="Ripple — track knock-on effects">
            <span class="panel-tab-title">Ripple</span>
            <span class="panel-tab-copy">Track knock-on effects</span>
          </button>
        </div>

        <div id="panel-deck-context" class="panel-deck-context-shell"></div>
      </div>

      <div id="panel-card-list" class="panel-cards"></div>
      <div id="panel-story-view" class="panel-story-view" hidden></div>

      <!-- Inline card inspector — replaces the floating modal -->
      <div id="panel-inspector-view" class="panel-inspector-view" hidden>
        <div class="panel-inspector-bar">
          <button id="panel-inspector-back-btn" type="button" class="panel-inspector-back-btn">← Back</button>
          <div id="panel-inspector-crumb" class="panel-inspector-crumb"></div>
        </div>
        <div id="card-editor-content" class="card-editor-content panel-inspector-content"></div>
      </div>

      <div class="panel-footer">
        <div id="panel-card-count" class="panel-card-count">Loading cards...</div>
        <div class="panel-footer-copy">Click a card on the board to inspect and edit it.</div>
      </div>
    </aside>

    <!-- Print-only export view. Hidden in screen mode; @media print swaps the
         entire app for this section so the browser's "Save as PDF" produces a
         clean, paper-formatted summary. Populated by JS on Export click. -->
    <section id="print-view" class="print-view" aria-hidden="true">
      <header class="print-header">
        <div class="print-brand">
          <span class="print-brand-diamond"></span>
          <span class="print-brand-name">Futures</span>
          <span class="print-brand-tag">Strategic Foresight Card Game</span>
        </div>
        <div class="print-meta">
          <div><strong>Room</strong> <span id="print-room"></span></div>
          <div><strong>Generated</strong> <span id="print-date"></span></div>
        </div>
      </header>

      <h1 id="print-title" class="print-title">Session summary</h1>

      <!-- 1. Framing -->
      <section class="print-section">
        <h2>Framing</h2>
        <div class="print-framing">
          <div class="print-framing-block">
            <div class="print-label">Question</div>
            <p id="print-framing-question" class="print-paragraph"></p>
          </div>
          <div class="print-framing-block">
            <div class="print-label">Goal</div>
            <p id="print-framing-goal" class="print-paragraph"></p>
          </div>
          <div class="print-framing-block" id="print-framing-track-block">
            <div class="print-label">Type of session</div>
            <p id="print-framing-track" class="print-paragraph"></p>
          </div>
        </div>
      </section>

      <!-- 2. Participants -->
      <section class="print-section">
        <h2>Participants</h2>
        <ul id="print-participants" class="print-participants"></ul>
      </section>

      <!-- 3. The pathway -->
      <section class="print-section">
        <h2>The pathway</h2>
        <p class="print-section-note">The story the team built — left to right, with curveballs as inline events.</p>
        <ol id="print-timeline" class="print-timeline"></ol>
      </section>

      <!-- 4. Ripples (side-effects) -->
      <section class="print-section" id="print-ripples-section">
        <h2>Ripple effects</h2>
        <p class="print-section-note">Knock-on consequences radiating from the pathway.</p>
        <ul id="print-ripples" class="print-ripples"></ul>
      </section>

      <!-- 5. Manual connections (drawn links) -->
      <section class="print-section" id="print-connections-section">
        <h2>Drawn connections</h2>
        <p class="print-section-note">Manual links the team drew between cards.</p>
        <ul id="print-connections" class="print-connections"></ul>
      </section>

      <!-- 6. Phase notes -->
      <section class="print-section" id="print-notes-section">
        <h2>Phase notes</h2>
        <ul id="print-notes" class="print-notes"></ul>
      </section>

      <!-- 7. Reflection / conclusion -->
      <section class="print-section print-section--reflection" id="print-reflection-section">
        <h2>Reflection</h2>
        <div id="print-reflection-content"></div>
      </section>

      <footer class="print-footer">
        <span>Futures Card Game · futures.hwbcards.web.app</span>
        <span id="print-page-tag"></span>
      </footer>
    </section>

    <!-- Framing-edit modal — opens from the framing strip's Edit button.
         Edits the composed question + goal as free text; the original shape
         and slots are preserved underneath in case the user wants to start
         from /framing again. -->
    <div id="framing-edit-modal" class="app-modal" role="dialog" aria-modal="true" aria-labelledby="framing-edit-modal-title" hidden>
      <div class="app-modal-card" data-card-type="beginning">
        <div class="app-modal-accent" aria-hidden="true"></div>
        <header class="app-modal-header">
          <span class="app-modal-chip">Framing</span>
          <h2 id="framing-edit-modal-title" class="app-modal-title">Refine the framing</h2>
          <p class="app-modal-copy">Tweak wording, fix grammar, or refine your goal — useful when slot text doesn't quite read right.</p>
        </header>
        <div class="app-modal-body">
          <label class="app-modal-field">
            <span class="app-modal-field-label">Question</span>
            <textarea id="framing-edit-question-input" rows="2" maxlength="280" placeholder="How might [system] respond to [challenge] by [horizon]?"></textarea>
          </label>
          <label class="app-modal-field">
            <span class="app-modal-field-label">Goal</span>
            <textarea id="framing-edit-goal-input" rows="3" maxlength="280" placeholder="The future state you're aiming for or testing against."></textarea>
          </label>
        </div>
        <div class="app-modal-actions">
          <button id="framing-edit-cancel-btn" type="button" class="app-modal-btn app-modal-btn--ghost">Cancel</button>
          <button id="framing-edit-save-btn" type="button" class="app-modal-btn app-modal-btn--primary">Save changes</button>
        </div>
      </div>
    </div>

    <!-- Custom-card modal — replaces native prompt() with an in-app dialog -->
    <div id="custom-card-modal" class="app-modal" role="dialog" aria-modal="true" aria-labelledby="custom-card-modal-title" hidden>
      <div class="app-modal-card" data-card-type="action">
        <div class="app-modal-accent" aria-hidden="true"></div>
        <header class="app-modal-header">
          <span id="custom-card-type-chip" class="app-modal-chip">Action</span>
          <h2 id="custom-card-modal-title" class="app-modal-title">Create a custom card</h2>
          <p class="app-modal-copy">Capture an idea, response, or observation that isn't in the deck.</p>
        </header>
        <div class="app-modal-body">
          <label class="app-modal-field">
            <span class="app-modal-field-label">Title</span>
            <input id="custom-card-title-input" type="text" maxlength="80" placeholder="Short label that reads on the card" required />
          </label>
          <label class="app-modal-field">
            <span class="app-modal-field-label">Description <span class="app-modal-field-optional">— optional</span></span>
            <textarea id="custom-card-desc-input" rows="3" maxlength="280" placeholder="Add context the group should see when they open the card."></textarea>
          </label>
        </div>
        <div class="app-modal-actions">
          <button id="custom-card-cancel-btn" type="button" class="app-modal-btn app-modal-btn--ghost">Cancel</button>
          <button id="custom-card-create-btn" type="button" class="app-modal-btn app-modal-btn--primary">Create card</button>
        </div>
      </div>
    </div>
  </div>
</GameLayout>

<style is:global>
  @import '../styles/board.css';
  @import '../styles/panel.css';
  @import '../styles/cards.css';
</style>

<script>
  import { initGame } from '../scripts/game/engine.js';
  import { initSync } from '../scripts/firebase/sync.js';

  // ── Storage helpers ──────────────────────────────────────────────────────────

  function safeStorageGet(key) {
    try { return window.localStorage.getItem(key); } catch { return null; }
  }

  function safeStorageSet(key, value) {
    try { window.localStorage.setItem(key, value); } catch { /* no-op */ }
  }

  // ── Demo state (FTR-DEMO room only) ─────────────────────────────────────────

  function buildDemoState(code) {
    const startX = 400, step = 260, top = 1070;
    return {
      roomCode: code,
      phase: 'planning',
      cards: {
        'demo-begin':  { cardId: 'demo-begin',  type: 'beginning', title: 'Rising Climate Pressure',      description: 'A public board needs a resilient, cross-agency response plan.',          position: { x: startX,           y: top } },
        'demo-act-1':  { cardId: 'demo-act-1',  type: 'action',    title: 'Commission Evidence Review',   description: 'Gather current climate risk data and lessons from other regions.',     position: { x: startX + step,     y: top } },
        'demo-act-2':  { cardId: 'demo-act-2',  type: 'action',    title: 'Hold Stakeholder Workshop',    description: 'Align local services, planners, and community groups on priorities.',   position: { x: startX + step * 2, y: top } },
        'demo-act-3':  { cardId: 'demo-act-3',  type: 'action',    title: 'Draft Policy Brief',           description: 'Turn the workshop outputs into a concrete implementation proposal.',   position: { x: startX + step * 3, y: top } },
        'demo-end':    { cardId: 'demo-end',     type: 'end',       title: 'Adopted Adaptation Plan',      description: 'A shared strategy is agreed and ready for delivery.',                  position: { x: startX + step * 4, y: top } },
        'demo-ripple': { cardId: 'demo-ripple',  type: 'ripple',    title: 'Cross-departmental Collaboration', description: 'The process breaks silos and creates a stronger delivery network.', position: { x: startX + step * 2, y: top - 260 } },
      },
      connections: [],
    };
  }

  // ── Boot ─────────────────────────────────────────────────────────────────────

  async function bootGame() {
    const params          = new URLSearchParams(window.location.search);
    const requestedRoom   = params.get('room');
    const roomCode        = (requestedRoom || 'FTR-DEMO').trim().toUpperCase();
    const playerName      = (params.get('name') || safeStorageGet('futures:last-player-name') || 'Planner').trim();
    const storageKey      = `futures:room:${roomCode}`;
    const isDemoRoom      = roomCode === 'FTR-DEMO';

    // Update topbar room code immediately (before async work). The
    // participant rail (`#participant-rail`) is the single source of truth
    // for "who's in the room" — no separate single-avatar element.
    const roomCodeButton = document.getElementById('room-code-button');
    if (!roomCodeButton) return;

    safeStorageSet('futures:last-player-name', playerName);
    roomCodeButton.textContent = roomCode;

    // Copy room code to clipboard on click.
    roomCodeButton.addEventListener('click', async () => {
      try { await navigator.clipboard.writeText(roomCode); } catch { /* no-op */ }
      roomCodeButton.textContent = `${roomCode} copied`;
      window.setTimeout(() => { roomCodeButton.textContent = roomCode; }, 1200);
    });

    // ── 1. Firebase sync (optional) ───────────────────────────────────────────
    // For the demo room we skip Firebase so it always starts fresh locally.
    let syncHandle = null;
    if (!isDemoRoom) {
      try {
        syncHandle = await initSync(roomCode, playerName);
      } catch (err) {
        console.warn('[boot] Firebase unavailable, falling back to localStorage:', err);
      }
    }

    // ── 2. Resolve initial state (Firebase → localStorage → blank) ───────────
    let initialState = syncHandle?.initialState ?? null;

    if (!initialState && !isDemoRoom) {
      // Room exists locally (e.g. offline reload) — use localStorage backup.
      try {
        const raw = safeStorageGet(storageKey);
        if (raw) initialState = JSON.parse(raw);
      } catch { /* ignore corrupt storage */ }
    }

    if (!initialState && isDemoRoom) {
      initialState = buildDemoState(roomCode);
    }

    // ── 3. Boot the game engine ───────────────────────────────────────────────
    // applyingRemote suppresses Firestore writes that would otherwise echo
    // when syncRemoteState() triggers internal emitStateChange() calls.
    let applyingRemote = false;

    const engine = initGame(roomCode, {
      playerName,
      sessionId: syncHandle?.sessionId || null,
      initialState,
      onStateChange(nextState) {
        // Always keep localStorage as an offline backup.
        safeStorageSet(storageKey, JSON.stringify(nextState));

        // Write to Firestore only when we're the origin of the change.
        if (!applyingRemote) {
          syncHandle?.writeState(nextState);
        }
      },
    });

    // ── 4. Subscribe to remote changes from other clients ────────────────────
    if (syncHandle) {
      syncHandle.subscribe((remoteState) => {
        applyingRemote = true;
        engine.syncRemoteState(remoteState);
        applyingRemote = false;
      });
    }

    // ── 5. Heartbeat — keep this tab marked as "online" in the synced state.
    // Other tabs render us as idle if our lastSeenAt drifts beyond ~45s.
    const HEARTBEAT_MS = 20 * 1000;
    window.setInterval(() => engine.heartbeat(), HEARTBEAT_MS);
  }

  if (document.readyState === 'loading') {
    window.addEventListener('DOMContentLoaded', bootGame, { once: true });
  } else {
    bootGame();
  }
</script>
